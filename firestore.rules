rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Yabalitsa Management Collections - These are separate from your existing app
    // Venues collection - public read for booking pages
    match /yabalitsa_venues/{venueId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pitches collection - public read for booking pages
    match /yabalitsa_pitches/{pitchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bookings collection - public read/write for booking pages
    match /yabalitsa_bookings/{bookingId} {
      allow read, write: if true;
    }
    
    // Customers collection (renamed from users to avoid conflict)
    match /yabalitsa_customers/{customerId} {
      allow read, write: if request.auth != null;
    }
    
    // TimeSlots collection
    match /yabalitsa_timeSlots/{slotId} {
      allow read, write: if request.auth != null;
    }
    
    // BlockedSlots collection
    match /yabalitsa_blockedSlots/{blockedSlotId} {
      allow read, write: if request.auth != null;
    }

    // BlockedDates collection
    match /yabalitsa_blockedDates/{blockedDateId} {
      allow read, write: if request.auth != null;
    }
    
    // VenueSettings collection
    match /yabalitsa_venueSettings/{settingId} {
      allow read, write: if request.auth != null;
    }
    
    // VenueOwners collection
    match /yabalitsa_venueOwners/{ownerId} {
      allow read, write: if request.auth != null;
    }

    // Academy Users collection (athletes, coaches, parents, admins)
    match /yabalitsa_academy_users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Squads collection (teams/age groups)
    match /yabalitsa_squads/{squadId} {
      allow read, write: if request.auth != null;
    }

    // User Groups collection (dynamic user categories per venue)
    match /yabalitsa_user_groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    // Tournament collections
    match /yabalitsa_tournaments/{tournamentId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_tournament_teams/{teamId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_tournament_players/{playerId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_tournament_matches/{matchId} {
      allow read, write: if request.auth != null;
    }

    // Subscriptions collection (one document per venue; doc ID == venueId)
    match /yabalitsa_subscriptions/{venueId} {
      // Allow reads for authenticated users who own the venue
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/yabalitsa_venues/$(venueId)).data.ownerId == request.auth.uid;
      // Allow writes from server-side API (no auth required for payment processing)
      allow write: if true;
    }

    // Payments collection (auto IDs)
    match /yabalitsa_payments/{paymentId} {
      // Only the owner of the venue can read its payments
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/yabalitsa_subscriptions/$(resource.data.subscriptionId)) &&
        get(/databases/$(database)/documents/yabalitsa_venues/$(resource.data.subscriptionId)).data.ownerId == request.auth.uid;
      // Allow writes from server-side API for payment processing
      allow write: if true;
    }

    // Training sessions
    match /yabalitsa_training_sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    // Support messages (rate limiting for Telegram bot)
    match /yabalitsa_support_messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Waitlist collection (public write for email collection)
    match /yabalitsa-waitlist/{waitlistId} {
      // Allow anyone to write (for email collection)
      allow write: if true;
      // Only authenticated users can read (for admin purposes)
      allow read: if request.auth != null;
    }
    
    // Your existing collections - DO NOT MODIFY THESE
    // These rules ensure your existing app continues to work
    match /games/{gameId} {
      allow read, write: if true; // Keep your existing rules
    }
    
    match /notification_logs/{logId} {
      allow read, write: if true; // Keep your existing rules
    }
    
    match /notification_requests/{requestId} {
      allow read, write: if true; // Keep your existing rules
    }
    
    match /users/{userId} {
      allow read, write: if true; // Keep your existing rules
    }
    
    match /venues/{venueId} {
      allow read, write: if true; // Keep your existing rules
    }
  }
}
