rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPER: Check if user is the venue owner
    // ============================================================
    function isVenueOwner(venueId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/yabalitsa_venues/$(venueId)).data.ownerId == request.auth.uid;
    }

    // ============================================================
    // PUBLIC-READ COLLECTIONS (needed for booking pages)
    // ============================================================

    // Venues - public read (booking page needs venue info)
    match /yabalitsa_venues/{venueId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pitches - public read (booking page needs pitch info)
    match /yabalitsa_pitches/{pitchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bookings - public read (booking page checks availability)
    // Write requires auth (was: if true — anyone could create/delete bookings)
    match /yabalitsa_bookings/{bookingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ============================================================
    // VENUE-SCOPED COLLECTIONS (auth required)
    // ============================================================

    // Customers
    match /yabalitsa_customers/{customerId} {
      allow read, write: if request.auth != null;
    }

    // TimeSlots
    match /yabalitsa_timeSlots/{slotId} {
      allow read, write: if request.auth != null;
    }

    // BlockedSlots
    match /yabalitsa_blockedSlots/{blockedSlotId} {
      allow read, write: if request.auth != null;
    }

    // BlockedDates
    match /yabalitsa_blockedDates/{blockedDateId} {
      allow read, write: if request.auth != null;
    }

    // VenueSettings
    match /yabalitsa_venueSettings/{settingId} {
      allow read, write: if request.auth != null;
    }

    // VenueOwners — read: any auth user, write: restricted
    // Coaches cannot change their own role or permissions
    match /yabalitsa_venueOwners/{ownerId} {
      allow read: if request.auth != null;
      // Allow create (for coach invitation via Admin SDK — also client needs this)
      allow create: if request.auth != null;
      // Allow update but block role/permissions changes unless user is venue owner
      allow update: if request.auth != null && (
        // If role or permissions are not being changed, allow
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions']))
        ||
        // If they are being changed, must be the venue owner
        isVenueOwner(resource.data.venueId)
      );
      allow delete: if request.auth != null;
    }

    // ============================================================
    // ACADEMY COLLECTIONS
    // ============================================================

    match /yabalitsa_academy_users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_squads/{squadId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_user_groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_academy_payments/{paymentId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_training_sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_broadcasts/{broadcastId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_evaluation_templates/{templateId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_player_evaluations/{evaluationId} {
      allow read, write: if request.auth != null;
    }

    // ============================================================
    // TOURNAMENT COLLECTIONS
    // ============================================================

    match /yabalitsa_tournaments/{tournamentId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_tournament_teams/{teamId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_tournament_players/{playerId} {
      allow read, write: if request.auth != null;
    }

    match /yabalitsa_tournament_matches/{matchId} {
      allow read, write: if request.auth != null;
    }

    // ============================================================
    // PAYMENT COLLECTIONS
    // ============================================================

    // Subscriptions — read: venue owner only, write: auth (server creates via client SDK)
    match /yabalitsa_subscriptions/{venueId} {
      allow read: if isVenueOwner(venueId);
      allow write: if request.auth != null;
    }

    // Payments — auth required for both read and write (was: write if true)
    match /yabalitsa_payments/{paymentId} {
      allow read, write: if request.auth != null;
    }

    // ============================================================
    // SUPPORT & MISC
    // ============================================================

    // Support messages (rate limiting for Telegram bot)
    match /yabalitsa_support_messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Waitlist — public write (email collection from landing page)
    match /yabalitsa-waitlist/{waitlistId} {
      allow write: if true;
      allow read: if request.auth != null;
    }

    // Email verifications (used by Admin SDK, but also needs client fallback)
    match /email_verifications/{emailId} {
      allow read, write: if true;
    }

    // Coupons — read only for authenticated users (admin manages via console)
    match /yabalitsa_coupons/{couponId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ============================================================
    // LEGACY COLLECTIONS — not used by yabalitsa app
    // Locked down to prevent abuse
    // ============================================================
    match /games/{gameId} {
      allow read, write: if false;
    }

    match /notification_logs/{logId} {
      allow read, write: if false;
    }

    match /notification_requests/{requestId} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if false;
    }

    match /venues/{venueId} {
      allow read, write: if false;
    }
  }
}
